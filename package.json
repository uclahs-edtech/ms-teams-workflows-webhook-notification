{
  "name": "microsoft-teams-workflows-webhook-notification",
  "version": "1.0.0",
  "description": "GitHub Action to send notifications to MS Teams via Workflow incoming webhook",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist --source-map --license licenses.txt",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "./scripts/test-action.sh",
    "lint": "eslint src/ __tests__/",
    "lint:fix": "eslint src/ __tests__/ --fix",
    "format": "prettier --write src/ __tests__/",
    "format:check": "prettier --check src/ __tests__/",
    "all": "npm run lint && npm run test:coverage && npm run build"
  },
  "overrides": {
    "undici": "^7.0.0"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.0",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "2.1.1",
    "jest": "^29.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
